# ============================================================
# Ghana SHS Frontend — Environment Variables
# Set these in your Vercel project settings, NOT in .env files.
# ============================================================

# ── Backend API URL (Render) ──────────────────────────────────
# Your Render service URL — no trailing slash
# Example: https://wamanafo-shs-api.onrender.com
NEXT_PUBLIC_API_URL="https://your-render-service.onrender.com"

# ── App URL (for local dev only) ─────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
